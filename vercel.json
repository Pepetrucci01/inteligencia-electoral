{
  "version": 2,
  "name": "inteligencia-electoral-2027",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/war-room",
      "dest": "/war_room_electoral_colima.html"
    },
    {
      "src": "/capturistas",
      "dest": "/panel_capturistas.html"
    },
    {
      "src": "/mapa",
      "dest": "/mapa_secciones_v2.html"
    },
    {
      "src": "/captura",
      "dest": "/modulo_captura.html"
    },
    {
      "src": "/meta",
      "dest": "/configurador_meta_estados.html"
    },
    {
      "src": "/reportes",
      "dest": "/modulo_reportes.html"
    },
    {
      "src": "/admin",
      "dest": "/modulo_admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*).(html|js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
